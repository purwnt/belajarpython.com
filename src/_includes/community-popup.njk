<!-- Community Popup Modal -->
<div
    id="community-popup" class="fixed inset-0 z-[100] hidden items-center justify-center px-4">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity opacity-0" id="community-popup-backdrop"></div>
    <!-- Modal Content -->
    <div
        class="relative w-full max-w-2xl bg-[#170101] rounded-3xl shadow-2xl overflow-hidden transform scale-95 opacity-0
            transition-all duration-300"
        id="community-popup-content">
        <!-- Close Button -->
        <button
            id="close-community-popup"
            class="absolute top-4 right-4 z-10 p-2 bg-white/20 hover:bg-white/40 rounded-full text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
        <div class="flex flex-col md:flex-row">
            <!-- Banner Image Section (Top on mobile, Left/Split on desktop if needed, but here full width or top is easier for
            generic banner) -->
            <!-- User asked for a "banner", usually top. But since aspect ratio 1200x600, it's a wide rectangle. -->
                <div class="relative md:h-80 h-64 w-full bg-slate-900 group"> <img
                    src="/img/banner-microdrama.png"
                    alt="MicroDrama Indonesia - AI Short Drama Platform"
                    class="w-full h-full object-cover object-top transition-transform duration-700">
            </div>
        </div>
        <!-- Content Section -->
        <div class="p-6 md:p-8 text-center -mt-6 relative z-10">
            <span class="inline-block py-1 px-3 rounded-full bg-red-100 text-red-600 text-xs font-bold tracking-wide mb-4 uppercase">
                MICRODRAMA INDONESIA
            </span>
            <h2 class="text-xl md:text-2xl font-bold text-white mb-2">
                Nonton & Buat Short Drama AI Gratis
            </h2>
            <p class="text-slate-300 mb-6 max-w-lg mx-auto leading-relaxed">
                Platform Microdrama AI pertama di Indonesia. Nonton short drama gratis atau buat sendiri dengan AI dalam hitungan menit, tanpa kru & kamera.
            </p>
            <!-- CTA Button -->
            <div class="max-w-lg mx-auto">
                <a
                    href="https://microdrama.id"
                    target="_blank"
                    class="w-full bg-red-600 text-white font-bold py-4 px-8 rounded-xl shadow-lg hover:shadow-xl
                        hover:-translate-y-0.5 transition-all duration-200 flex items-center justify-center gap-2 text-lg">
                    <span>Coba Gratis Sekarang</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                    </svg>
                </a>
                <p class="text-xs text-slate-400 mt-4 italic">
                    100% Gratis untuk dicoba. Bagian dari ekosistem MicroDrama Indonesia.
                </p>
            </div>
        </div>
            <!-- Success Message (Hidden by default) -->
            <div id="devmode-success-message" class="hidden">
                <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-slate-800 mb-2">Terima Kasih!</h3>
                <p class="text-slate-600">Selamat! Anda telah sukses mendaftar di newsletter.</p>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const popup = document.getElementById('community-popup');
        const backdrop = document.getElementById('community-popup-backdrop');
        const content = document.getElementById('community-popup-content');
        const closeBtn = document.getElementById('close-community-popup');

        // Check if user already saw popup
        const hasSeenPopup = localStorage.getItem('microdrama_popup_seen');
        // Show popup after 1 second if not seen
        if (! hasSeenPopup) {
            setTimeout(() => {
                showPopup();
            }, 1000);
        }
        function showPopup() {
            popup.classList.remove('hidden');
            popup.classList.add('flex');
            setTimeout(() => {
                backdrop.classList.remove('opacity-0');
                content.classList.remove('opacity-0', 'scale-95');
                content.classList.add('opacity-100', 'scale-100');
            }, 10);
        }
        function hidePopup() {
            backdrop.classList.add('opacity-0');
            content.classList.remove('opacity-100', 'scale-100');
            content.classList.add('opacity-0', 'scale-95');
            setTimeout(() => {
                popup.classList.add('hidden');
                popup.classList.remove('flex');
            }, 300);
            localStorage.setItem('microdrama_popup_seen', 'true');
        }
        closeBtn.addEventListener('click', hidePopup);
        backdrop.addEventListener('click', hidePopup);
    });
</script>